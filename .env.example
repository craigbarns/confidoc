# ==============================================================================
# ConfiDoc Backend — Environment Variables
# ==============================================================================
# Copier ce fichier en .env et adapter les valeurs

# ---- Application ----
APP_NAME=ConfiDoc
APP_ENV=development
DEBUG=true
SECRET_KEY=CHANGE-ME-IN-PRODUCTION-USE-openssl-rand-hex-64
LOG_LEVEL=DEBUG

# ---- API ----
API_V1_PREFIX=/api/v1
# CORS : pour l’UI servie sur le même domaine que l’API (/ui → /api), souvent suffisant tel quel.
# Ajoutez votre URL publique si vous appelez l’API depuis un autre origine (SPA local, autre sous-domaine).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://VOTRE-APP.up.railway.app

# ---- Database (PostgreSQL) ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=confidoc
POSTGRES_PASSWORD=confidoc_dev_password
POSTGRES_DB=confidoc
DATABASE_URL=postgresql+asyncpg://confidoc:confidoc_dev_password@localhost:5432/confidoc

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ---- Celery ----
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ---- MinIO / S3 Storage ----
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=confidoc_minio
MINIO_SECRET_KEY=confidoc_minio_secret
MINIO_BUCKET=confidoc-documents
MINIO_USE_SSL=false

# ---- JWT ----
JWT_SECRET_KEY=CHANGE-ME-USE-openssl-rand-hex-64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Encryption ----
ENCRYPTION_MASTER_KEY=CHANGE-ME-USE-python-c-from-cryptography.fernet-import-Fernet;print(Fernet.generate_key().decode())

# ---- File Upload ----
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,tiff
