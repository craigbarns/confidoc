{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://confidoc.fr/schemas/golden_sets.json",
  "title": "ConfiDoc Golden Sets",
  "description": "Vérité terrain + sous-ensemble comparable à export-structured-dataset (fields.value/confidence/source).",
  "type": "object",
  "required": ["golden_sets"],
  "additionalProperties": false,
  "properties": {
    "golden_sets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["doc_type", "source_filename", "golden_reference", "expected_api_subset"],
        "additionalProperties": false,
        "properties": {
          "doc_type": {
            "type": "string",
            "enum": ["bilan", "compte_resultat", "fiscal_2072", "etat_immobilisations"]
          },
          "source_filename": { "type": "string", "minLength": 1 },
          "golden_reference": {
            "type": "object",
            "required": ["fields"],
            "additionalProperties": false,
            "properties": {
              "fields": {
                "type": "object",
                "minProperties": 1,
                "additionalProperties": {
                  "type": "object",
                  "required": ["value"],
                  "properties": {
                    "value": {},
                    "notes": { "type": "string" }
                  },
                  "additionalProperties": true
                }
              },
              "tables": { "type": "object" },
              "metadata": { "type": "object" }
            }
          },
          "expected_api_subset": {
            "type": "object",
            "required": ["fields"],
            "additionalProperties": false,
            "properties": {
              "fields": {
                "type": "object",
                "minProperties": 1,
                "additionalProperties": {
                  "type": "object",
                  "required": ["value", "confidence", "source"],
                  "properties": {
                    "value": {},
                    "confidence": { "type": "number" },
                    "source": { "type": "string" }
                  },
                  "additionalProperties": false
                }
              },
              "tables": { "type": "object" }
            }
          }
        }
      }
    }
  }
}
